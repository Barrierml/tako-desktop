{
    "productName": "Tako",
    "version": "0.3.6",
    "identifier": "tech.shiroha.tako",
    "build": {
        "beforeBuildCommand": "bun run prepare",
        "beforeDevCommand": "bun run prepare",
        "frontendDist": "./resources/loading"
    },
    "app": {
        "security": {
            "csp": null
        }
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://tako-releases.shiroha.tech/check/{target}/{arch}/{current_version}"
            ],
            "pubkey": ""
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "signingIdentity": "-",
            "entitlements": null,
            "exceptionDomain": null,
            "minimumSystemVersion": "10.13"
        },
        "resources": {
            "resources/hub-bundle.js": "resources/hub-bundle.js",
            "resources/cli-bundle.js": "resources/cli-bundle.js",
            "resources/catalog.json": "resources/catalog.json",
            "resources/web-dist": "resources/web-dist"
        }
    }
}
